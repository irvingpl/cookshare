{
  "name": "cookshare",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter cookshare-backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter @cookshare/shared build && pnpm --filter cookshare-backend build && pnpm --filter frontend build",
    "build:shared": "pnpm --filter @cookshare/shared build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter frontend lint"
  }
}
