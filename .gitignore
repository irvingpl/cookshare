# dependencies
node_modules/

# build output
dist/
frontend/.next/
**/*.tsbuildinfo

# env files
.env
.env.local
.env.*.local

# database
*.db
*.db-shm
*.db-wal

# uploads (keep directory structure)
backend/src/uploads/*
!backend/src/uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# k8s — 실제 시크릿은 커밋하지 않음 (secret.yaml은 예시값이므로 예외적으로 허용)
# 실제 운영 시: k8s/secret.yaml을 .gitignore에 추가하고 별도 관리

# editor — 개인 설정(*.vsix, launch-local)은 제외, 공유 설정은 커밋
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/*.code-snippets
.idea/
